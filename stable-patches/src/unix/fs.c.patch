+#if defined(__MVS__)
+static struct timeval uv__fs_to_timeval(double time) {
+  struct timeval tv;
+  if (uv__isinf(time))
+    // 0 is for char tv_usec_pad[4]
+    return (struct timeval){UTIME_NOW, "", UTIME_NOW};
+  else if (uv__isnan(time))
+    return (struct timeval){UTIME_OMIT, "", UTIME_OMIT};
+
+  tv.tv_sec  = time;
+  tv.tv_usec = (time - tv.tv_sec) * 1e6;
+  if (tv.tv_usec < 0) {
+    tv.tv_usec += 1e6;
+    tv.tv_sec -= 1;
+  }
+  return tv;
+}
+#endif
